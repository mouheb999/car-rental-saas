# Copy this file to `.env.local` and fill in your credentials.
# You'll find the Supabase keys in your Supabase project → Settings → API.

# --------------------------------------------------------
# PUBLIC (exposed to the browser) — safe to ship
# --------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --------------------------------------------------------
# SERVER-ONLY (never exposed to the browser) — KEEP SECRET
# --------------------------------------------------------
# Supabase "service_role" key: bypasses RLS. Used exclusively by
# server-side API routes under /api/admin/*. NEVER prefix with
# NEXT_PUBLIC_ and never commit the real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Password for the admin dashboard. Pick a strong string.
ADMIN_PASSWORD=change-me-to-a-strong-password
